GEMINI_API_KEY=your_gemini_api_key_here
# Best quality analysis/reasoning model (override if needed)
GEMINI_MODEL=gemini-2.5-pro
# Best quality image world-building model (override if needed)
NANOBANANA_MODEL=gemini-3-pro-image-preview

# Overshoot.ai segmentation provider
OVERSHOOT_API_KEY=your_overshoot_api_key_here
OVERSHOOT_BASE_URL=https://api.overshoot.ai
OVERSHOOT_SEGMENT_PATH=/v1/segment
OVERSHOOT_ADAPTER=generic_v1
# Set true for dev flow without real Overshoot credentials
OVERSHOOT_MOCK_MODE=true
OVERSHOOT_TIMEOUT_SEC=45
OVERSHOOT_MAX_RETRIES=3
# If live API fails, fallback to mock segmentation instead of failing hard
OVERSHOOT_MOCK_ON_ERROR=true

# Realtime camera defaults (frontend can override at runtime)
REALTIME_DEFAULT_FRAME_INTERVAL_SEC=10
REALTIME_MAX_UPLOAD_MB=8
